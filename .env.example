# Copy to .env for local dev. All vars are prefixed ANS_ (see app/config.py).

ANS_ENV=local
ANS_DEBUG=true
ANS_LOG_LEVEL=INFO

# Datastores
ANS_DATABASE_URL=postgresql+asyncpg://ans:ans@localhost:5432/ans
ANS_REDIS_URL=redis://localhost:6379/0

# Ingestion / idempotency
ANS_INGEST_MAX_BODY_BYTES=65536
ANS_IDEMPOTENCY_TTL_SECONDS=86400

# Dedup + rate limiting
ANS_DEDUP_WINDOW_SECONDS=300
ANS_RATE_LIMIT_CAPACITY=20
ANS_RATE_LIMIT_REFILL_PER_SEC=1.0

# Dispatcher
ANS_WORKER_BATCH_SIZE=50
ANS_WORKER_POLL_INTERVAL_MS=100

# Priority queue (02): starvation guard, visibility timeout, info backpressure
ANS_QUEUE_STARVATION_FACTOR=10
ANS_INFLIGHT_TTL_SECONDS=60
ANS_INFO_SHED_ENABLED=false
ANS_INFO_SHED_THRESHOLD=100000

# Channels
ANS_CHANNEL_TIMEOUT_SECONDS=5.0
ANS_CHANNEL_MAX_RETRIES=3
ANS_CIRCUIT_FAILURE_THRESHOLD=5
ANS_CIRCUIT_RESET_SECONDS=30

# Auth — comma-separated API keys (empty in local => anonymous allowed)
# ANS_API_KEYS=["key-one","key-two"]

# Observability
# ANS_OTEL_EXPORTER_ENDPOINT=http://localhost:4318/v1/traces
ANS_METRICS_ENABLED=true
