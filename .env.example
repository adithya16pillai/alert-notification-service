# Copy to .env for local dev. All vars are prefixed ANS_ (see app/config.py).

ANS_ENV=local
ANS_DEBUG=true
ANS_LOG_LEVEL=INFO

# Datastores
ANS_DATABASE_URL=postgresql+asyncpg://ans:ans@localhost:5432/ans
ANS_REDIS_URL=redis://localhost:6379/0

# Ingestion / idempotency
ANS_INGEST_MAX_BODY_BYTES=65536
ANS_IDEMPOTENCY_TTL_SECONDS=86400

# Dedup + rate limiting
ANS_DEDUP_WINDOW_SECONDS=300
ANS_RATE_LIMIT_CAPACITY=20
ANS_RATE_LIMIT_REFILL_PER_SEC=1.0

# Dispatcher
ANS_WORKER_BATCH_SIZE=50
ANS_WORKER_POLL_INTERVAL_MS=100

# Priority queue (02): starvation guard, visibility timeout, info backpressure
ANS_QUEUE_STARVATION_FACTOR=10
ANS_INFLIGHT_TTL_SECONDS=60
ANS_INFO_SHED_ENABLED=false
ANS_INFO_SHED_THRESHOLD=100000

# Channels (04). Per-channel timeout/retry/backoff are constants in
# app/channels/policy.py; these are circuit-breaker tunables + fallbacks.
ANS_CHANNEL_TIMEOUT_SECONDS=5.0
ANS_CHANNEL_MAX_RETRIES=3
ANS_CIRCUIT_FAILURE_THRESHOLD=5
ANS_CIRCUIT_RESET_SECONDS=30

# Provider credentials (04 §9). Backend "env" reads ANS_SECRET_<NAME>; "aws"
# reads AWS Secrets Manager under the prefix. NEVER commit real secrets.
ANS_SECRETS_BACKEND=env
ANS_AWS_SECRETS_PREFIX=ans/
ANS_WEBHOOK_SIGNING_ENABLED=true
# Email (SES SMTP) — credentials come from the secrets backend, not here.
ANS_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
ANS_SMTP_PORT=587
ANS_SMTP_FROM=alerts@example.com
# Twilio sender id; SID/token come from the secrets backend.
ANS_TWILIO_FROM_NUMBER=

# Example local secrets (ANS_SECRET_<NAME>). For dev only.
# ANS_SECRET_SLACK_BOT_TOKEN=xoxb-...
# ANS_SECRET_SES_SMTP_USER=...
# ANS_SECRET_SES_SMTP_PASSWORD=...
# ANS_SECRET_TWILIO_ACCOUNT_SID=AC...
# ANS_SECRET_TWILIO_AUTH_TOKEN=...

# Auth — comma-separated API keys (empty in local => anonymous allowed)
# ANS_API_KEYS=["key-one","key-two"]

# Observability
# ANS_OTEL_EXPORTER_ENDPOINT=http://localhost:4318/v1/traces
ANS_METRICS_ENABLED=true
